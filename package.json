{
  "name": "hello-gatsby",
  "description": "My starter kit for Gatsby projects based on gatsby-starter-typescript-plus",
  "version": "1.0.0",
  "private": false,
  "author": "Chris Tham <chris.tham@hellotham.com>",
  "keywords": [
    "gatsby",
    "material-ui",
    "typescript",
    "storybook",
    "jest",
    "cypress"
  ],
  "license": "MIT",
  "scripts": {
    "build": "gatsby build",
    "clean": "rimraf public",
    "deploy": "gatsby build --prefix-paths && gh-pages -d public",
    "develop": "gatsby develop",
    "format": "prettier --write \"src/**/*.{ts,tsx,md}\"",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "start": "npm run develop",
    "lc": "npm run type-check && npm run lint",
    "test": "jest",
    "type-check": "tsc",
    "storybook": "start-storybook -p 6006",
    "storybook:build": "build-storybook -c .storybook -o .out",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "start-server-and-test develop http://localhost:8000 cy:open",
    "test:e2e:ci": "start-server-and-test develop http://localhost:8000 cy:run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@material-table/core": "6.4.4",
    "@mdi/js": "^7.2.96",
    "@mdi/react": "^1.6.1",
    "@mui/icons-material": "^5.14.3",
    "@mui/material": "^5.14.3",
    "@reduxjs/toolkit": "^1.9.5",
    "babel-plugin-styled-components": "^2.1.4",
    "classnames": "^2.3.2",
    "dotenv": "^16.3.1",
    "gatsby": "^5.11.0",
    "gatsby-plugin-emotion": "^8.11.0",
    "gatsby-plugin-image": "^3.11.0",
    "gatsby-plugin-sharp": "^5.11.0",
    "gatsby-source-filesystem": "^5.11.0",
    "gatsby-transformer-sharp": "^5.11.0",
    "mathjs": "^11.9.1",
    "modern-normalize": "^2.0.0",
    "normalize.css": "^8.0.1",
    "polished": "^4.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.2",
    "redux-thunk": "^2.4.2",
    "tss-react": "^4.8.8",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "@babel/core": "^7.22.10",
    "@storybook/addon-actions": "^7.2.1",
    "@storybook/addon-info": "^5.3.21",
    "@storybook/addon-viewport": "^7.2.1",
    "@storybook/preset-typescript": "^3.0.0",
    "@storybook/react": "^7.2.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/classnames": "^2.3.1",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.9",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@types/react-redux": "^7.1.25",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^9.1.3",
    "babel-plugin-jsx-remove-data-test-id": "^3.0.0",
    "babel-plugin-remove-graphql-queries": "^5.11.0",
    "babel-preset-gatsby": "^3.11.0",
    "babel-preset-react-app": "^10.0.1",
    "cypress": "^12.17.3",
    "eslint": "^8.46.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gh-pages": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "prettier": "^3.0.1",
    "react-test-renderer": "^18.2.0",
    "rimraf": "^5.0.1",
    "start-server-and-test": "^2.0.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.4.4"
  },
  "overrides": {
    "ansi-regex@>=3.0.0 <3.0.1": "3.0.1",
    "ansi-regex@>=4.0.0 <4.1.1": "4.1.1",
    "brace-expansion@>=1.0.0 <1.1.13": "1.1.13",
    "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
    "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
